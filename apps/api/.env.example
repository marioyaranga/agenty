# Variables locales (opcional). En Render usar el dashboard.



# Origen del front en Vercel (CORS). Varias URLs separadas por coma.

WEB_ORIGIN=http://localhost:3000



# Supabase (Fase 2 — validación JWT y comprobación de tenant en /v1/me)

SUPABASE_URL=https://YOUR_PROJECT.supabase.co

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Audiencia esperada del access token (por defecto en proyectos Supabase: authenticated)

JWT_AUDIENCE=authenticated

# Gemini (Fase 4 embeddings + Fase 5 chat del agente)

GEMINI_API_KEY=your-gemini-api-key

# LangSmith / LangChain (Fase 5 — opcional; sin esto el chat sigue funcionando)

# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=default
